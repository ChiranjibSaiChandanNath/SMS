# ============================================================
#  TEMPLATE — Copy this file to .env and fill in your values
#  DO NOT put real secrets in this file
# ============================================================

# Django Secret Key — generate one at: https://djecrety.ir/
DJANGO_SECRET_KEY=your-django-secret-key-here

# Google reCAPTCHA Secret Key — get from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here

# Firebase Cloud Messaging Server Key — get from Firebase Console > Project Settings > Cloud Messaging
FIREBASE_SERVER_KEY=your-firebase-server-key-here

# Gmail credentials for sending emails (use App Password, not your real password)
EMAIL_ADDRESS=your-gmail@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
